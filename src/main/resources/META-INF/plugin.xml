<idea-plugin>
    <id>com.github.sofiafo.codeexplorer</id>
    <name>CodeExplorer</name>
    <vendor>Sofia</vendor>
    <description><![CDATA[
        Analisa a estrutura interna de projetos Java e visualiza relações entre classes,
        interfaces e componentes diretamente dentro do IntelliJ IDEA.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="CodeExplorer"
                secondary="false"
                anchor="right"
                factoryClass="com.sofia.codeexplorer.ui.CodeExplorerToolWindowFactory"/>
    </extensions>

    <actions>
        <action
                id="com.sofia.codeexplorer.AnalyzeAction"
                class="com.sofia.codeexplorer.actions.AnalyzeProjectAction"
                text="Analyze Project Dependencies">
            <add-to-group group-id="AnalyzeMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
